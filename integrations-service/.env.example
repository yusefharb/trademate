# Tendd Integrations Service Config
NODE_ENV=development
PORT=4000

# Platform API (this project)
PLATFORM_API_URL=http://localhost:3001

# Twilio (optional, features disabled without these)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Calendar (optional)
BOOKING_PROVIDER=calendly
CALENDLY_API_KEY=
CALCOM_API_KEY=

# Google Business Profile (optional)
GMB_CLIENT_ID=
GMB_CLIENT_SECRET=
GMB_REFRESH_TOKEN=

# Vapi.ai (optional)
VAPI_API_KEY=
VAPI_AGENT_ID=