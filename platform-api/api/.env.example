# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/tendd.db

# Email (for magic link auth)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@tendd.app

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for CORS + magic link redirects)
FRONTEND_URL=http://localhost:5173