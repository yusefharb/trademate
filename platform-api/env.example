# ─── Server ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Integrations Service (the other system) ──────
INTEGRATIONS_SERVICE_URL=http://localhost:4000

# ─── JWT Secret (for user logins) ─────────────────
JWT_SECRET=trademate-dev-secret-change-in-production

# ─── Stripe (leave blank — works without for testing) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (leave blank — magic links print to console in dev) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@trademateapp.uk